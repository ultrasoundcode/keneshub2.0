generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  LAWYER
  ADMIN
}

enum SubscriptionPlan {
  FREE
  PRO
  BUSINESS
}

enum CreditorType {
  BVU
  MFO
  COLLECTOR
  OTHER
}

enum CaseStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model User {
  id                String           @id @default(cuid())
  email             String           @unique
  password          String?
  name              String?
  avatar            String?
  role              Role             @default(USER)
  subscriptionPlan  SubscriptionPlan @default(FREE)
  stripeCustomerId  String?          @unique
  emailVerified     Boolean          @default(false)
  verificationToken String?
  resetToken        String?
  resetTokenExpiry  DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  lawyerProfile  LawyerProfile?
  debtCases      DebtCase[]
  conversations  Conversation[]
  usage          Usage[]
  documents      Document[]
  consultations  Consultation[]  @relation("UserConsultations")
  auditLogs      AuditLog[]

  @@map("users")
}

model LawyerProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  licenseNumber  String
  verified       Boolean  @default(false)
  specialization String[]
  rating         Float    @default(0)
  bio            String?
  experience     Int?
  hourlyRate     Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  consultations Consultation[] @relation("LawyerConsultations")

  @@map("lawyer_profiles")
}

model DebtCase {
  id           String       @id @default(cuid())
  userId       String
  title        String
  totalDebt    Float
  creditorName String?
  creditorType CreditorType
  status       CaseStatus   @default(OPEN)
  description  String?
  riskScore    Int?
  aiAnalysis   String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents Document[]

  @@map("debt_cases")
}

model Conversation {
  id        String    @id @default(cuid())
  userId    String
  title     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@map("conversations")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String
  content        String
  tokensUsed     Int?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Usage {
  id         String   @id @default(cuid())
  userId     String
  tokensUsed Int      @default(0)
  month      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
  @@map("usage")
}

model Document {
  id         String   @id @default(cuid())
  userId     String
  debtCaseId String?
  fileName   String
  fileUrl    String
  fileType   String
  summary    String?
  createdAt  DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  debtCase DebtCase? @relation(fields: [debtCaseId], references: [id], onDelete: SetNull)

  @@map("documents")
}

model Consultation {
  id          String   @id @default(cuid())
  userId      String
  lawyerId    String
  scheduledAt DateTime
  duration    Int      @default(30)
  status      String   @default("pending")
  notes       String?
  price       Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User          @relation("UserConsultations", fields: [userId], references: [id], onDelete: Cascade)
  lawyer LawyerProfile @relation("LawyerConsultations", fields: [lawyerId], references: [id], onDelete: Cascade)

  @@map("consultations")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}
